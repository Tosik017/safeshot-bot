# Токен від @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ID дозволених груп (через кому/пробіл). Супергрупа = відʼємний, -100...
# Порожньо + ALLOW_OPEN_MODE=false → бот НЕ стартує (secure-by-default).
ALLOWED_GROUP_IDS=-1001234567890

# Топіки, де бот вимкнений: group:thread, group:general (через кому/пробіл)
DISABLED_THREADS=

# Відкритий режим (бот працює в будь-якій групі). За замовчуванням ВИМКНЕНО.
ALLOW_OPEN_MODE=false

# DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# Локально/VPS із seccomp: "on" вмикає справжній Chromium sandbox.
# На Render Free лишати порожнім (sandbox недоступний).
CHROMIUM_SANDBOX=
